    |

Room Temperature = INTEG ( (Heat Gain from People - Heat Loss) / Air Heat Capacity, Initial Temperature)
    ~ Degree C
    ~

    |

Heat Gain from People = people_count * Heat per Person
    ~ Watt
    ~
    |

Heat Loss = (Room Temperature - Outside Temperature) * Insulation Factor
    ~ Watt
    ~

    |

people_count = 0
    ~ person
    ~
    |

Heat per Person = 10000
    ~ Watt/person
    ~ теплоотдача человека, норма 100

    |

Air Heat Capacity = 10
    ~ Joule/Degree C
    ~ чем меньше это число, тем меньше энергии нужно, чтобы поднять температуру на 1 градус, норма 2000
    |

Outside Temperature = 20
    ~ Degree C
    ~

    |

Insulation Factor = 1
    ~ Watt/Degree C
    ~ скорость остывания помещения, норма 15
    |

Initial Temperature = 22
    ~ Degree C
    ~
    |
